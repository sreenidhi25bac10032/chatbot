% Start the chatbot
start:-
    write('Hello! I am your chatbot. Type "bye." to exit.'), nl,
    chat.

% Chat loop
chat:-
    write('You: '),
    read(Input),
    (   Input == bye -> 
        write('Bot: Goodbye!'), nl
    ;   respond(Input),
        chat
    ).

% Responses
respond(hello):-
    write('Bot: Hi there!'), nl.

respond(how_are_you):-
    write('Bot: I am just a program, but I am fine!'), nl.

respond(name):-
    write('Bot: I am a cool chatbot.'), nl.

respond(what_is_algorithm):-
    write('Bot: Algorithm is a step-by-step procedure for solving a problem or achieving a goal.'), nl.

respond(what_is_the_meaning_of_food_web_in_ecosystem):-
    write('Bot: Network of food chains showing who eats whom.'), nl.

respond(can_you_help_me):-
    write('Bot: Yes, I am always here to help you.'), nl.

respond(approx):-
    write('Bot: Sorry, I am not able to understand.'), nl.

respond(thankyou):-
    write('Bot: You are always welcome.'), nl.

respond(full_form_of_ai):-
